#!/bin/bash
# wd-launch — one-click Waydroid starter for the desktop launcher.
# Ensures the whole NVIDIA/Venus stack is up (recovering from crashes),
# then opens the full-ui window. Safe to run repeatedly.
set -u

WAYDROID_DIR="$HOME/repos/waydroid"
XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
export XDG_RUNTIME_DIR WAYLAND_DISPLAY

cd "$WAYDROID_DIR" || exit 1

notify() { notify-send -a Waydroid "$1" "${2:-}" 2>/dev/null || true; }

session_alive() {
    systemctl --user is-active --quiet wd-session.service
}

guest_booted() {
    [ "$(python3 waydroid.py prop get sys.boot_completed 2>/dev/null)" = "1" ]
}

# Detect a crashed/zombie stack: session unit dead, or guest not answering.
if ! session_alive || ! guest_booted; then
    notify "Waydroid" "(re)starting the stack…"
    python3 waydroid.py session stop >/dev/null 2>&1
    systemctl --user restart wd-venus.service
    sudo -n systemctl restart wd-container.service || {
        notify "Waydroid" "FAILED: wd-container restart (sudo -n)"; exit 1; }
    sleep 2
    systemd-run --user --unit=wd-session --collect --working-directory="$PWD" \
        --setenv=WAYLAND_DISPLAY="$WAYLAND_DISPLAY" \
        --setenv=XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" \
        python3 waydroid.py session start || {
        notify "Waydroid" "FAILED: session start"; exit 1; }
    for _ in $(seq 1 60); do
        guest_booted && break
        sleep 2
    done
    if ! guest_booted; then
        notify "Waydroid" "FAILED: guest did not boot in 120 s"; exit 1
    fi
fi

exec python3 waydroid.py show-full-ui
