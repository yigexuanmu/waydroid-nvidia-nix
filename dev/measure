#!/usr/bin/env bash
# measure — the canonical smoothness bench: fling the app DRAWER (local,
# deterministic content — horizontal workspace swipes land on the Discover
# news feed, whose network content varies run-to-run) and read HWUI frame
# stats. Numbers go in STATE.md's Log. Requires a booted stack.
# Usage: dev/measure            (app-drawer fling, 5 up/down swipe pairs)
#        dev/measure <pkg>      (bench a specific package instead)
source "$(dirname "$(readlink -f "$0")")/env.sh"
need_sudo

PKG="${1:-com.android.launcher3}"

say "fling bench: $PKG (wake, home, open app drawer, 5x vertical fling)"
guest "
  input keyevent KEYCODE_WAKEUP; input keyevent KEYCODE_MENU; sleep 1
  input keyevent KEYCODE_HOME; sleep 1
  input swipe 1280 1200 1280 300 150; sleep 1
  input swipe 1280 1100 1280 340 100; sleep 0.5
  input swipe 1280 340 1280 1100 100; sleep 0.5
  dumpsys gfxinfo $PKG reset >/dev/null
  for i in 1 2 3 4 5; do
    input swipe 1280 1100 1280 340 100; sleep 0.5
    input swipe 1280 340 1280 1100 100; sleep 0.5
  done
  dumpsys gfxinfo $PKG | grep -E 'Total frames|Janky frames|50th|90th|95th|99th'
  input keyevent KEYCODE_HOME
"
echo
echo "DoD @250Hz: median<=4ms p95<=4ms janky<5% | baseline 2026-07-11: median 6ms p90 10ms p99 14ms janky 19.8%"
