#!/usr/bin/env bash
# health — post-restart sanity check before trusting a measurement.
# Verifies: boot, the active renderer, crash count, KWin dmabuf errors, and the
# hwc mode diagnostics. Cheap; run it after every dev/restart.
source "$(dirname "$(readlink -f "$0")")/env.sh"
need_sudo

say "boot / props"
guest 'getprop sys.boot_completed; getprop waydroid.active_apps; getprop ro.hardware.egl; getprop ro.hardware.vulkan; getprop debug.hwui.renderer; getprop debug.renderengine.backend' 2>/dev/null || warn "container not answering"

say "SurfaceFlinger renderer (want: ANGLE ... c1a25085dd9e over venus)"
guest 'dumpsys SurfaceFlinger | grep -iE "GLES:|renderer"' 2>/dev/null | head -3 || true

say "crashes since boot (want 0; 1 early hwc_binder_thread SIGABRT is known/benign)"
n=$(guest 'logcat -d -b crash 2>/dev/null | grep -c Cmdline; :' 2>/dev/null || echo '?')
echo "  crash Cmdline count: $n"

say "hwc mode diagnostics (last few)"
guest 'logcat -d 2>/dev/null | grep -E "hwc_set #|full-ui:|single-window:" | tail -5' 2>/dev/null || true

say "KWin dmabuf bind errors (want 0)"
kn=$(journalctl --user -t kwin_wayland --since -60s 2>/dev/null | grep -c GL_INVALID || true)
echo "  GL_INVALID lines (last 60s): $kn"

say "host renderer + GPU"
systemctl --user is-active "$VENUS_UNIT" | sed 's/^/  wd-venus: /'
nvidia-smi --query-gpu=utilization.gpu,memory.used --format=csv,noheader 2>/dev/null | sed 's/^/  5090: /' || true
