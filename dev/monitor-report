#!/usr/bin/env python3
"""Aggregate a dev/monitor capture into actionable frame/transport/GPU rates."""
import csv, json, math, re, statistics, sys
from collections import defaultdict
from pathlib import Path

run = Path(sys.argv[1])
meta = {}
for line in (run / "meta.env").read_text().splitlines():
    if "=" in line:
        k, v = line.split("=", 1); meta[k] = v
secs = float(meta.get("seconds", 0) or 0)
period = float(meta.get("stats_period", 0) or 0)

def pct(xs, p):
    if not xs: return None
    ys = sorted(xs); return ys[min(len(ys)-1, math.ceil(len(ys)*p/100)-1)]
def num(s):
    try: return float(re.sub(r"[^0-9.+-]", "", s))
    except ValueError: return None

# SurfaceFlinger: select the busiest package layer, preferring SurfaceView.
ts = (run / "timestats.txt").read_text(errors="replace")
pkg = meta.get("package", "")
best = None
for sec in ts.split("layerName = ")[1:]:
    name = sec.splitlines()[0]
    if pkg not in name: continue
    m = re.search(r"totalFrames = (\d+)", sec); frames = int(m.group(1)) if m else 0
    key = ("SurfaceView" in name, frames)
    if frames and (best is None or key > best[0]): best = (key, name, sec)
frame = {}
if best:
    _, name, sec = best
    def grab(pat, cast=float):
        m = re.search(pat, sec); return cast(m.group(1)) if m else None
    frame = {"layer": name, "frames": grab(r"totalFrames = (\d+)", int),
             "dropped": grab(r"droppedFrames = (\d+)", int),
             "janky": grab(r"jankyFrames = (\d+)", int),
             "sf_average_fps": grab(r"averageFPS = ([0-9.]+)")}
    frame["window_fps"] = frame["frames"] / secs if secs else None
    hm = re.search(r"present2present histogram is as below:\n([^\n]+)", sec)
    if hm:
        vals=[]
        for ms, count in re.findall(r"(\d+)ms=(\d+)", hm.group(1)):
            vals.extend([int(ms)] * int(count))
        frame.update({f"p2p_p{p}_ms": pct(vals,p) for p in (50,90,99)})

# Journal stats. A block is keyed by journal PID + attributed guest process.
header_re = re.compile(r"^vtest stats(?: \[([^]]+)\])?: polls (\d+), imports query/real (\d+)/(\d+)$")
cmd_re = re.compile(r"^vtest stats(?: \[([^]]+)\])?:\s+([A-Z0-9_]+)\s+(\d+) calls\s+avg\s+(\d+) us\s+total (\d+) us$")
groups = defaultdict(lambda: {"samples":0,"polls":0,"query_imports":0,"real_imports":0,"commands":defaultdict(lambda:{"calls":0,"us":0})})
for line in (run / "venus.jsonl").read_text(errors="replace").splitlines():
    try: rec=json.loads(line)
    except json.JSONDecodeError: continue
    msg=rec.get("MESSAGE", ""); pid=str(rec.get("_PID", "?"))
    m=header_re.match(msg)
    if m:
        name=m.group(1) or "unknown"; g=groups[(name,pid)]
        g["samples"]+=1; g["polls"]+=int(m.group(2)); g["query_imports"]+=int(m.group(3)); g["real_imports"]+=int(m.group(4)); continue
    m=cmd_re.match(msg)
    if m:
        name=m.group(1) or "unknown"; c=groups[(name,pid)]["commands"][m.group(2)]
        c["calls"]+=int(m.group(3)); c["us"]+=int(m.group(5))

contexts=[]
for (name,pid),g in groups.items():
    observed=g["samples"]*period
    if not observed: continue
    commands={k:{**v,"rate":v["calls"]/observed,"avg_us":v["us"]/v["calls"] if v["calls"] else 0} for k,v in g["commands"].items()}
    submit=sum(commands.get(k,{}).get("rate",0) for k in ("SUBMIT_CMD","SUBMIT_CMD2","SUBMIT_CMD2_TIMELINE"))
    contexts.append({"name":name,"pid":pid,"observed_s":observed,"submit_s":submit,
                     "real_import_s":g["real_imports"]/observed,"query_import_s":g["query_imports"]/observed,
                     "commands":commands})
contexts.sort(key=lambda x:x["submit_s"], reverse=True)

# GPU telemetry and a conservative starvation hint.
gpu=defaultdict(list)
with (run / "gpu.csv").open(newline="") as f:
    for row in csv.DictReader(f):
        for k in ("util_gpu","util_mem","memory_mib","power_w","power_limit_w","sm_mhz","mem_mhz","temp_c"):
            v=num(row.get(k,""))
            if v is not None: gpu[k].append(v)
gpu_summary={k:{"p50":pct(v,50),"p95":pct(v,95),"max":max(v)} for k,v in gpu.items() if v}
util=gpu_summary.get("util_gpu",{}).get("p50",0) or 0
memutil=gpu_summary.get("util_mem",{}).get("p50",0) or 0
power=gpu_summary.get("power_w",{}).get("p50",0) or 0
limit=gpu_summary.get("power_limit_w",{}).get("p50",0) or 0
starved=bool(util>=90 and limit and power/limit<0.40 and memutil<35)

health={k:meta.get(k) for k in ("venus_pid_before","venus_pid_after","restarts_before","restarts_after","crashes_before","crashes_after")}
health["kwin_errors"] = sum(1 for l in (run/"kwin.log").read_text(errors="replace").splitlines() if "GL_INVALID" in l or "INVALID_WL_BUFFER" in l)
report={"meta":meta,"frames":frame,"contexts":contexts,"gpu":gpu_summary,"starved_signature":starved,"health":health}
(run/"report.json").write_text(json.dumps(report,indent=2)+"\n")

print(f"capture: {meta.get('label')}  package: {pkg}  window: {secs:.0f}s")
if frame:
    print(f"frames: {frame['frames']}  window fps {frame.get('window_fps'):.1f}  SF averageFPS {frame.get('sf_average_fps')}  dropped {frame.get('dropped')}  janky {frame.get('janky')}  p2p p50/p90/p99 {frame.get('p2p_p50_ms')}/{frame.get('p2p_p90_ms')}/{frame.get('p2p_p99_ms')} ms")
else: print("frames: no presenting package layer found")
if gpu_summary:
    print(f"gpu: util p50/p95 {gpu_summary['util_gpu']['p50']:.0f}/{gpu_summary['util_gpu']['p95']:.0f}%  power p50/p95 {gpu_summary['power_w']['p50']:.0f}/{gpu_summary['power_w']['p95']:.0f}W  mem-util p50 {gpu_summary['util_mem']['p50']:.0f}%  SM p50 {gpu_summary['sm_mhz']['p50']:.0f}MHz")
    if starved: print("gpu diagnosis: busy/low-power/low-memory-traffic signature — submission or dependency starvation is likely")
print("transport contexts (rates/s; sorted by submits):")
fps=frame.get("window_fps",0) if frame else 0
for c in contexts[:10]:
    per=(c['submit_s']/fps) if fps else 0
    hot=sorted(c["commands"].items(),key=lambda kv:kv[1]["rate"],reverse=True)[:3]
    hot_s=", ".join(f"{k} {v['rate']:.1f}/s" for k,v in hot)
    print(f"  {c['name']} pid={c['pid']}: submits {c['submit_s']:.1f}/s ({per:.2f}/present), imports real/query {c['real_import_s']:.1f}/{c['query_import_s']:.1f}/s; {hot_s}")
stable=(health.get("venus_pid_before")==health.get("venus_pid_after") and health.get("restarts_before")==health.get("restarts_after") and health["kwin_errors"]==0)
print(f"health: {'stable' if stable else 'CHANGED'}; venus pid {health.get('venus_pid_before')}->{health.get('venus_pid_after')}, restarts {health.get('restarts_before')}->{health.get('restarts_after')}, KWin errors {health['kwin_errors']}")
