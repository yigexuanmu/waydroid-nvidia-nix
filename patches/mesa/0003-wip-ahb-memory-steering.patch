+    * uncached query below costs three renderer roundtrips per call.
+    */
+   uint64_t ino;
+   if (vn_dma_buf_props_cache_lookup(dev, fd, out_mem_type_bits, &ino))
+      return VK_SUCCESS;
+
    struct vn_renderer_bo *bo;
    VkResult result = vn_renderer_bo_create_from_dma_buf(
       dev->renderer, 0 /* size */, fd, 0 /* flags */, &bo);
@@ -614,6 +707,9 @@ vn_get_memory_dma_buf_properties(struct vn_device *dev,
 
    *out_mem_type_bits = props.memoryTypeBits;
 
+   if (ino)
+      vn_dma_buf_props_cache_insert(dev, ino, props.memoryTypeBits);
+
    return VK_SUCCESS;
 }
 
