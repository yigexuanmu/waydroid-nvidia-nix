+                 (cur->propertyFlags | VK_MEMORY_PROPERTY_HOST_CACHED_BIT)) ==
+                   (cur->propertyFlags | VK_MEMORY_PROPERTY_HOST_CACHED_BIT)) {
+               steered_info = *pAllocateInfo;
+               steered_info.memoryTypeIndex = i;
+               pAllocateInfo = &steered_info;
