@@ -584,6 +622,54 @@ vn_GetMemoryFdKHR(VkDevice device,
    return VK_SUCCESS;
 }
 
+/* dma_buf inodes come from a monotonic counter (never reused) and a buffer's
+ * memoryTypeBits are immutable, so a cache hit is always sound.  Returns
+ * true on a hit; on a miss *out_ino is the fd's inode, or 0 when it could
+ * not be determined (don't cache).
+ */
+static bool
+vn_dma_buf_props_cache_lookup(struct vn_device *dev,
+                              int fd,
+                              uint32_t *out_mem_type_bits,
+                              uint64_t *out_ino)
+{
+   struct vn_dma_buf_props_cache *cache = &dev->dma_buf_props_cache;
+   struct stat st;
+
+   *out_ino = 0;
+   if (fstat(fd, &st))
+      return false;
+
+   simple_mtx_lock(&cache->mutex);
+   for (uint32_t i = 0; i < cache->count; i++) {
+      if (cache->entries[i].ino == st.st_ino) {
+         *out_mem_type_bits = cache->entries[i].mem_type_bits;
+         simple_mtx_unlock(&cache->mutex);
+         return true;
+      }
+   }
+   simple_mtx_unlock(&cache->mutex);
+
+   *out_ino = st.st_ino;
+   return false;
+}
+
+static void
+vn_dma_buf_props_cache_insert(struct vn_device *dev,
+                              uint64_t ino,
+                              uint32_t mem_type_bits)
+{
+   struct vn_dma_buf_props_cache *cache = &dev->dma_buf_props_cache;
+
+   simple_mtx_lock(&cache->mutex);
+   cache->entries[cache->next].ino = ino;
+   cache->entries[cache->next].mem_type_bits = mem_type_bits;
+   cache->next = (cache->next + 1) % VN_DMA_BUF_PROPS_CACHE_SIZE;
+   if (cache->count < VN_DMA_BUF_PROPS_CACHE_SIZE)
+      cache->count++;
+   simple_mtx_unlock(&cache->mutex);
+}
