+/* VTEST_STATS=<seconds>: periodically log per-command dispatch counts and
+ * times (and context poll wakeups) to stderr, per client process.  Costs two
+ * clock_gettime per dispatched command when enabled, nothing when disabled.
+ */
+#define VTEST_STATS_MAX_CMDS 64
+static struct {
+   int period;        /* seconds; 0 = off, -1 = env not checked yet */
+   int64_t next_dump;
+   uint64_t count[VTEST_STATS_MAX_CMDS];
+   uint64_t ns[VTEST_STATS_MAX_CMDS];
+   uint64_t polls;
+} vtest_stats = { .period = -1 };
+
+static int64_t vtest_stats_now(void)
+{
+   struct timespec ts;
+   clock_gettime(CLOCK_MONOTONIC, &ts);
+   return (int64_t)ts.tv_sec * 1000000000 + ts.tv_nsec;
+}
