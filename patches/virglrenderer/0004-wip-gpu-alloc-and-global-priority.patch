+int vtest_resource_alloc_gpu(uint32_t length_dw)
+{
+   struct vtest_context *ctx = vtest_get_current_context();
+   uint32_t req[VCMD_RESOURCE_ALLOC_GPU_SIZE];
+   uint32_t resp_buf[VTEST_HDR_SIZE + VCMD_RESOURCE_ALLOC_GPU_RESP_SIZE];
+   uint32_t *resp = &resp_buf[VTEST_CMD_DATA_START];
+   int fd = -1;
+   int ret;
+
+   if (length_dw != VCMD_RESOURCE_ALLOC_GPU_SIZE)
+      return -EINVAL;
+
+   ret = ctx->input->read(ctx->input, req, sizeof(req));
+   if (ret != sizeof(req))
+      return -1;
+
+   const uint32_t width = req[VCMD_RESOURCE_ALLOC_GPU_WIDTH];
+   const uint32_t height = req[VCMD_RESOURCE_ALLOC_GPU_HEIGHT];
+   const uint32_t drm_format = req[VCMD_RESOURCE_ALLOC_GPU_FORMAT];
+   const uint32_t flags = req[VCMD_RESOURCE_ALLOC_GPU_FLAGS];
+
+   uint32_t stride = 0;
+   uint64_t modifier = 0;
+   uint64_t size = 0;
+
+   if (!width || !height || width > 32768 || height > 32768) {
+      ret = -EINVAL;
+   } else if (flags & VCMD_ALLOC_GPU_FLAG_MAPPABLE) {
+      ret = vtest_gpu_alloc_cpu(width, height, drm_format, &stride, &size, &fd);
+   } else {
+      ret = vtest_gpu_alloc_gpu(width, height, drm_format, &stride, &modifier,
+                                &size, &fd);
+   }
+   if (ret)
+      report_failed_call("vtest_gpu_alloc", ret);
+
+   memset(resp_buf, 0, sizeof(resp_buf));
+   resp_buf[VTEST_CMD_LEN] = VCMD_RESOURCE_ALLOC_GPU_RESP_SIZE;
+   resp_buf[VTEST_CMD_ID] = VCMD_RESOURCE_ALLOC_GPU;
+   resp[VCMD_RESOURCE_ALLOC_GPU_RESP_STATUS] = ret ? (uint32_t)-ret : 0;
+   resp[VCMD_RESOURCE_ALLOC_GPU_RESP_STRIDE] = stride;
+   /* both paths allocate linear, so the CPU view stride == GPU stride */
+   resp[VCMD_RESOURCE_ALLOC_GPU_RESP_MAP_STRIDE] = stride;
+   resp[VCMD_RESOURCE_ALLOC_GPU_RESP_MODIFIER_LO] = (uint32_t)modifier;
+   resp[VCMD_RESOURCE_ALLOC_GPU_RESP_MODIFIER_HI] = (uint32_t)(modifier >> 32);
+   resp[VCMD_RESOURCE_ALLOC_GPU_RESP_SIZE_LO] = (uint32_t)size;
+   resp[VCMD_RESOURCE_ALLOC_GPU_RESP_SIZE_HI] = (uint32_t)(size >> 32);
+
+   ret = vtest_block_write(ctx->out_fd, resp_buf, sizeof(resp_buf));
+   if (ret >= 0 && fd >= 0)
+      ret = vtest_send_fd(ctx->out_fd, fd);
+
+   if (fd >= 0)
+      close(fd);
+
+   return ret >= 0 ? 0 : ret;
+}
